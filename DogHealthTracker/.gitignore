*.env
Secrets.swift
APIKeys.swift
Config.xcconfig

# ─── Build artifacts ──────────────────────────────────────────────────────────
build/
*.o
*.d

# ─── Test results ─────────────────────────────────────────────────────────────
TestResults/
*.xcresult
